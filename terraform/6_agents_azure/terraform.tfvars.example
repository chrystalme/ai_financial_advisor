subscription_id                   = "your-subscription-id"
resource_group                    = "alex-rg"
location                          = "eastus"
agents                            = ["planner", "tagger", "reporter", "charter", "retirement"]

azure_openai_endpoint             = "https://alex-openai-xxxxxx.openai.azure.com/"
azure_openai_key                  = "from guide 2"
azure_openai_deployment           = "gpt-4o"
azure_openai_embedding_deployment = "text-embedding-3-small"

postgres_host                     = "alex-db-xxxxxx.postgres.database.azure.com"
key_vault_name                    = "alex-dbkv-xxxxxx"
db_secret_uri                     = "https://alex-dbkv-xxxxxx.vault.azure.net/secrets/alex-db-credentials"

azure_search_endpoint             = "https://alex-search-xxxxxx.search.windows.net"
azure_search_key                  = "from guide 3"
azure_search_index                = "alex-docs"

polygon_api_key                   = "your-polygon-key"
polygon_plan                      = "free"

shared_app_insights               = true

langfuse_public_key               = ""
langfuse_secret_key               = ""
langfuse_host                     = "https://us.cloud.langfuse.com"

openai_api_key                    = ""
