project_id               = "your-gcp-project-id"
region                   = "us-central1"
vertex_model_id          = "vertex_ai/gemini-2.5-pro"
cloudsql_connection_name = "your-gcp-project-id:us-central1:alex-db"
db_secret_name           = "alex-db-credentials"
vector_index_endpoint_id = "projects/.../indexEndpoints/..."
deployed_index_id        = "alex_docs_v1"
polygon_api_key          = "your-polygon-key"
polygon_plan             = "free"

# Optional LangFuse
langfuse_public_key = ""
langfuse_secret_key = ""
langfuse_host       = "https://us.cloud.langfuse.com"

# Optional: enables OpenAI Agents SDK tracing
openai_api_key = ""

agents = ["planner", "tagger", "reporter", "charter", "retirement"]
